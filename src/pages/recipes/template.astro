---
import BaseLayout from '../../layouts/BaseLayout.astro';

const repositoryUrl = import.meta.env.PUBLIC_GITHUB_REPOSITORY_URL;
const templatePath = 'src/content/recipes/_template.md';
const templateUrl = repositoryUrl
  ? `${repositoryUrl.replace(/\/$/, '')}/blob/main/${templatePath}`
  : `/${templatePath}`;
---

<BaseLayout title="Recipe Template | Recipe Shelf" description="Recipe template and format guide.">
  <section class="page-intro narrow">
    <p class="eyebrow">Recipe format</p>
    <h1>Use the recipe template for new entries.</h1>
    <p>
      Copy the template file, rename it with a short slug, fill in the structured
      fields, then commit it to GitHub.
    </p>
    <a class="button" href={templateUrl} rel="noreferrer">Open template</a>
  </section>
</BaseLayout>
