---
import type { CollectionEntry } from 'astro:content';

interface Props {
  recipe: CollectionEntry<'recipes'>;
}

const { recipe } = Astro.props;
const { data } = recipe;
const ingredients = data.ingredients.flatMap((group) =>
  group.ingredients.map((ingredient) => ingredient.name)
);
const searchText = [
  data.title,
  data.description,
  data.categories.join(' '),
  data.tags.join(' '),
  ingredients.join(' ')
]
  .join(' ')
  .toLowerCase();
---

<article
  class="recipe-card"
  data-recipe-card
  data-search={searchText}
  data-categories={data.categories.join('|').toLowerCase()}
  data-tags={data.tags.join('|').toLowerCase()}
>
  <a href={`${import.meta.env.BASE_URL}recipes/${recipe.id.replace(/\.md$/, '')}/`}>
    <span class="card-kicker">{data.categories[0] ?? 'Recipe'}</span>
    <h2>{data.title}</h2>
    <p>{data.description}</p>
    <dl class="meta-list compact">
      <dt>Serves</dt><dd>{data.originalServings}</dd>
    </dl>
    <ul class="tag-list" aria-label={`Tags for ${data.title}`}>
      {data.tags.slice(0, 4).map((tag) => <li>{tag}</li>)}
    </ul>
  </a>
</article>
