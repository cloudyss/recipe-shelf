---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A personal, searchable recipe collection.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#416154" />
    <meta name="description" content={description} />
    <link rel="manifest" href={`${base}manifest.webmanifest`} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <header class="site-header">
      <nav class="site-nav" aria-label="Primary navigation">
        <a class="brand" href={base}>Recipe Shelf</a>
        <a href={base}>Recipes</a>
        <a href={`${base}recipes/template/`}>Template</a>
        <a href="https://github.com/" rel="noreferrer">GitHub</a>
      </nav>
    </header>
    <main id="content">
      <slot />
    </main>
    <script is:inline define:vars={{ base }}>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register(`${base}sw.js`).catch(() => {});
        });
      }
    </script>
  </body>
</html>
